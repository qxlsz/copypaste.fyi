# copypaste.fyi Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Bind address for the Rocket server
ROCKET_ADDRESS=0.0.0.0

# Bind port for the Rocket server
ROCKET_PORT=8000

# Rust log level: trace, debug, info, warn, error
RUST_LOG=info

# =============================================================================
# PERSISTENCE BACKEND
# =============================================================================
# Choose storage backend: memory (default), redis, or vault
# - memory: In-memory storage (data lost on restart)
# - redis: Upstash Redis (requires UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN)
# - vault: HashiCorp Vault (requires COPYPASTE_VAULT_* variables)
COPYPASTE_PERSISTENCE_BACKEND=memory

# =============================================================================
# REDIS BACKEND (required when COPYPASTE_PERSISTENCE_BACKEND=redis)
# =============================================================================

# Upstash Redis REST API URL (get from Upstash console)
# Must start with http:// or https://
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io

# Upstash Redis auth token (get from Upstash console)
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Redis key prefix for namespacing (optional)
COPYPASTE_REDIS_KEY_PREFIX=paste:

# =============================================================================
# VAULT BACKEND (required when COPYPASTE_PERSISTENCE_BACKEND=vault)
# =============================================================================

# Vault server URL (must start with http:// or https://)
COPYPASTE_VAULT_ADDR=https://your-vault-server:8200

# Vault authentication token (minimum 20 characters required)
COPYPASTE_VAULT_TOKEN=your_vault_token_here_minimum_20_chars

# KV secrets engine mount point (optional, default: secret)
COPYPASTE_VAULT_MOUNT=secret

# Vault Enterprise namespace (optional, for Vault Enterprise only)
# COPYPASTE_VAULT_NAMESPACE=admin

# Key prefix within the mount point (optional, default: copypaste)
COPYPASTE_VAULT_PREFIX=copypaste

# =============================================================================
# BLOCKCHAIN ANCHORING (optional)
# =============================================================================

# Blockchain relay service endpoint for paste anchoring
# ANCHOR_RELAY_ENDPOINT=https://your-relay-service.com

# API key for the relay service
# ANCHOR_RELAY_API_KEY=your_relay_api_key

# =============================================================================
# TOR/ONION SERVICE (optional)
# =============================================================================

# Tor onion service hostname (for hidden service deployments)
# COPYPASTE_ONION_HOST=youronionaddress.onion

# Suppress Tor-related log messages (optional, default: true)
# Accepted values: 1, true, yes, on (enable) / 0, false, no, off (disable)
# COPYPASTE_TOR_SUPPRESS_LOGS=true

# =============================================================================
# CRYPTO VERIFICATION
# =============================================================================

# OCaml crypto verifier service endpoint (optional, default: http://localhost:8001)
# CRYPTO_VERIFIER_URL=http://localhost:8001

# =============================================================================
# BUILD INFORMATION (set automatically in Docker builds)
# =============================================================================

# GIT_COMMIT=abc1234
# GIT_COMMIT_MESSAGE="Your commit message"
# COPYPASTE_VERSION=1.0.0
